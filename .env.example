# Odysseus environment config
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Admin setup
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=changeme

# Ollama — local (default)
# Use host.docker.internal if Ollama is on the same machine
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama Cloud fallback
# Get your key at https://ollama.com → Account → API Keys
# Swap OLLAMA_BASE_URL to https://api.ollama.com/v1 and add key below
OLLAMA_API_KEY=

# Optional: other OpenAI-compatible endpoints
# OPENAI_API_KEY=
# OPENAI_BASE_URL=